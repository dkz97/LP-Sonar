# OKX OnchainOS MCP
OKX_MCP_URL=https://web3.okx.com/api/v1/onchainos-mcp
OKX_ACCESS_KEY=your_key_here

# OKX CEX Public API
OKX_CEX_BASE_URL=https://www.okx.com

# Redis
REDIS_URL=redis://localhost:6379/0

# Monitoring config
UNIVERSE_SCAN_INTERVAL=900        # seconds, 15min
HOT_POLL_INTERVAL=300             # seconds, 5min
FOCUS_POLL_INTERVAL=60            # seconds, 1min

# Admission thresholds
MIN_TVL_USD=50000                 # $50k
MIN_VOLUME_5M_USD=10000           # $10k
HOT_TO_FOCUS_Z_SCORE=2.0
FOCUS_TO_HOT_Z_SCORE=1.0
FOCUS_COOLDOWN_ROUNDS=3           # consecutive rounds below threshold before demotion

# Supported chains (comma-separated chainIndex values)
MONITORED_CHAINS=501,8453,56

# Per-chain Top N from ranking
UNIVERSE_TOP_N=200
