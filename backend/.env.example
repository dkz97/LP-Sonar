# OKX OnchainOS MCP
OKX_MCP_URL=https://web3.okx.com/api/v1/onchainos-mcp
OKX_ACCESS_KEY=your_key_here

# OKX CEX Public API
OKX_CEX_BASE_URL=https://www.okx.com

# Redis
REDIS_URL=redis://localhost:6379/0

# Monitoring config
UNIVERSE_SCAN_INTERVAL=900        # seconds, 15min
HOT_POLL_INTERVAL=300             # seconds, 5min
FOCUS_POLL_INTERVAL=60            # seconds, 1min

# Admission thresholds
MIN_TVL_USD=50000                 # $50k
MIN_VOLUME_5M_USD=10000           # $10k
HOT_TO_FOCUS_Z_SCORE=2.0
FOCUS_TO_HOT_Z_SCORE=1.0
FOCUS_COOLDOWN_ROUNDS=3           # consecutive rounds below threshold before demotion

# Supported chains (comma-separated chainIndex values)
MONITORED_CHAINS=501,8453,56

# Per-chain Top N from ranking
UNIVERSE_TOP_N=200

# ── Range Recommendation Engine ────────────────────────────────────────────────

# Utility scoring weights (must sum to 1.0 for fee+il+breach+rebalance+quality)
# RANGE_WEIGHT_FEE=0.30
# RANGE_WEIGHT_IL=0.25
# RANGE_WEIGHT_BREACH=0.25
# RANGE_WEIGHT_REBALANCE=0.10
# RANGE_WEIGHT_QUALITY=0.10

# OHLCV bars to fetch per recommendation (1H bars; 300 ≈ 12.5 days)
# RANGE_OHLCV_BARS=300

# Redis TTL for cached recommendations (seconds)
# RANGE_CACHE_TTL=300

# ── Uniswap V3 fee tier (P2.1.2 — on-chain RPC, no API key needed) ────────────
# Primary: eth_call to pool.fee() via public RPC. Defaults below work out of the box.
# Override with your own RPC URL for higher rate limits (e.g. Alchemy/Infura/QuickNode).
# Set to empty string to disable RPC for that chain (falls back to static lookup).
ETH_RPC_URL=https://ethereum.publicnode.com
BASE_RPC_URL=https://base.publicnode.com
POLYGON_RPC_URL=https://polygon-bor.publicnode.com
BSC_RPC_URL=https://bsc-dataseed.bnbchain.org

# Secondary (optional): Uniswap V3 subgraph — only needed if you have a private Graph node
# or a paid API key. The Graph decentralized network requires auth; leave empty otherwise.
# UNISWAP_V3_SUBGRAPH_ETHEREUM=
# UNISWAP_V3_SUBGRAPH_BASE=
# UNISWAP_V3_SUBGRAPH_POLYGON=

# Optional: Uniswap V4 BSC subgraph. Recommended for V4 poolId analysis because
# RPC-only fallback can read spot state, but not enough metadata for full history-driven recommendations.
# Format: https://gateway.thegraph.com/api/{api_key}/subgraphs/id/{subgraph_id}
# UNISWAP_V4_SUBGRAPH_BSC=

# ── Calibration parameters ─────────────────────────────────────────────────────
# These are normally set by scripts/calibrate.py and stored in data/calibration.json.
# Override here only if you want to pin specific values via environment.
# ENV takes precedence over calibration.json which takes precedence over code defaults.

# Actionability thresholds (evidence_score required for "standard" rating)
# CALIBRATION_GROWING_STANDARD_THRESHOLD=0.65
# CALIBRATION_MATURE_STANDARD_THRESHOLD=0.55

# Replay weight interpolation: evidence in [lo, hi] maps replay_weight 0→1
# REPLAY_WEIGHT_LOWER_BOUND=0.25
# REPLAY_WEIGHT_UPPER_BOUND=0.75

# Confidence floor: recommendation_confidence below this value triggers caution downgrade.
# 0.0 = disabled (default). Enable only after calibration run.
# CONFIDENCE_FLOOR=0.0

# Regime-aware confidence scale factors (JSON dict).
# CONFIDENCE_REGIME_SCALES={"range_bound":1.0,"trend_up":0.85,"trend_down":0.85,"chaotic":0.70}

# Path to offline calibration output (relative to working directory when running uvicorn)
# CALIBRATION_FILE_PATH=data/calibration.json
